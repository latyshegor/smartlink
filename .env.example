# Postgres connection (local dev or Supabase). DIRECT_URL = non-pooled (migrations).
DATABASE_URL="postgresql://user:pass@host:5432/smartlink"
DIRECT_URL="postgresql://user:pass@host:5432/smartlink"

# Admin session secret — 32+ random chars. Generate: openssl rand -hex 32
SESSION_SECRET="change_me_to_a_long_random_string_min_32_chars"

# Seed admin login (used by `prisma db seed`)
ADMIN_EMAIL="artist@smartlink.app"
ADMIN_PASSWORD="demo1234"

# Public base URL — used for OAuth redirect + QR codes
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Spotify OAuth (developer.spotify.com → Create App). Needed for pre-save.
# Add <NEXT_PUBLIC_BASE_URL>/api/spotify/callback to the app's Redirect URIs.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
